# ==========================================
# 📦 DEPENDENCIAS Y ARTEFACTOS DE NODE (Angular/Tailwind)
# ==========================================
# Ignora node_modules en la raíz y en cualquier subcarpeta de proyectos
**/node_modules/
**/dist/
**/tmp/
**/out-files/

# Log de errores de npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 🚀 CACHÉ Y COMPILACIÓN (Angular, TS y Tailwind)
# ==========================================
# Caché local de compilación de Angular 19+
**/.angular/

# Caché de compilación de TypeScript (si usas tsc por separado)
*.tsbuildinfo

# Caché de optimización de Tailwind CSS
.tailwindcss/
.postcss/

# ==========================================
# 🔐 CONFIGURACIONES LOCALES Y SECRETOS
# ==========================================
# Archivos de entorno con credenciales, tokens o llaves de APIs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 🛠️ EDITORES DE CÓDIGO (VS Code, JetBrains, etc.)
# ==========================================
# Visual Studio Code (mantiene tus configuraciones locales de pantalla/historial)
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains / WebStorm / IntelliJ
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# 💻 ARCHIVOS BASURA DEL SISTEMA OPERATIVO
# ==========================================
# Linux / Unix (Arch, CachyOS, Ubuntu, etc.)
*~
.fuse_hidden*
.directory
.trash/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
